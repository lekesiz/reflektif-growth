# reflektif-growth — ortam değişkenleri (DEĞERLER repo'ya girmez; bu şablon)
# Kopyala: cp .env.example .env  ve doldur.

# --- Faz 0 (iskele) — zorunlu ---
DATABASE_URL=postgres://mikail@localhost:5432/reflektif_growth   # lokal PG (Docker gerekmez)
LOG_LEVEL=info                        # trace|debug|info|warn|error
TICK_WORKER_TURNS=5                   # her launchd tick'te kaç worker turu
WORKER_LEASE_SECONDS=120             # iş lease süresi (< tick aralığı)
JOB_STALE_HOURS=12                   # run_after bundan eskiyse "gönderme, yeniden zamanla" (staleness guard)
AGENT_DAILY_CAP_USD=5                # loop başına günlük LLM/araç maliyet tavanı; aşımda GLOBAL pause

# --- Faz 1+ — model (hibrit: Ollama kütle + Vertex-EU yazar) ---
# OLLAMA_HOST=http://127.0.0.1:11434
# OLLAMA_MODEL=qwen3:30b
# GOOGLE_CLOUD_PROJECT=
# GOOGLE_CLOUD_LOCATION=europe-west4   # KVKK: EU residency
# GOOGLE_SERVICE_ACCOUNT_JSON=

# --- Faz 2+ — çok-kanal gönderim ---
# SENDING_DOMAIN=reflektif.info        # ana reflektif.net'ten izole
# RESEND_API_KEY=
# RESEND_WEBHOOK_SECRET=
# IMAP_HOST=  IMAP_USER=  IMAP_PASS=   # lokal reply-poll
# EMAIL_VERIFY_PROVIDER=millionverifier   # SMTP-probe kendin yapma
# EMAIL_VERIFY_API_KEY=
# WHATSAPP_BUSINESS_TOKEN=  WHATSAPP_PHONE_ID=   # resmî WABA
# LINKEDIN_MODE=semi-auto              # ban riski: agresif otomasyon YOK

# --- Kontrol yüzeyi ---
# TELEGRAM_BOT_TOKEN=                  # mevcut NETZ bot olabilir
# TELEGRAM_CHAT_ID=
# NOTION_TOKEN=                        # 'Reflektif CRM' integration token (kasada; secrets:pull ile .env'e gelir)
# NOTION_CRM_DATABASE_ID=              # sır DEĞİL (db id); boşsa kod-varsayılanı kullanılır
